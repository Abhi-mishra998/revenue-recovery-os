# ---- Engine selection (rollback knob) ----
# mongo (default) keeps the current behaviour. postgres routes every repo call
# to the SQL backend once the migration script has run.
DB_ENGINE=mongo

# ---- Mongo (always required while DB_ENGINE=mongo or during cutover) ----
MONGO_URL=mongodb://localhost:27017
DB_NAME=revora_dev

# ---- Postgres (required when DB_ENGINE=postgres; safe to leave set always) ----
POSTGRES_URL=postgresql://revora:revora@localhost:5432/revora

# ---- Auth + crypto ----
JWT_SECRET=replace-with-a-32+-char-secret
# ADMIN_EMAILS is comma-separated; all listed users are admins. Single-value
# ADMIN_EMAIL is still honored for backward compatibility but takes lower priority.
ADMIN_EMAILS=founder@bytehubble.com
ADMIN_PASSWORD=replace-with-a-real-password

# ---- AI ----
EMERGENT_LLM_KEY=
AI_PROVIDER=emergent_gemini
AI_MODEL=gemini-2.5-flash

# ---- CORS + ops ----
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
# AUDIT_SIGNING_KEY=base64-encoded-32-byte-ed25519-secret  # optional; auto-generated to db.settings if omitted
